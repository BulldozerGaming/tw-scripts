    'linear-gradient(to bottom, #947a62 0%, #7b5c3d 22%, #6c4824 30%, #6c4824 100%)';

gear.style.borderRadius = '1px';
gear.style.border = '1px solid #000';

gear.style.padding = '0px 0px';
gear.style.height = 'auto';
gear.style.minWidth = 'auto';
gear.style.textAlign = 'center';
gear.style.verticalAlign = 'baseline';

gear.title = 'Automatikus indítás beállítása';

gear.addEventListener('click', showSettingsHUD);



arrivalCell.appendChild(gear);

}

function triggerAttack() {



    const btn =
        document.querySelector(
            '#troop_confirm_submit'
        );

    if (!btn) {
        return;
    }

    btn.click();
}









function scheduleAttack() {

    if (attackTimeout) {
        clearTimeout(attackTimeout);
    }

    const delay =
        attackTimestampMs -
        unsafeWindow.Timing.getCurrentServerTime();

    if (delay <= 0) {

        triggerAttack();

        localStorage.removeItem(STORAGE_KEY);

        attackTimeStr = '';
        attackTimestampMs = 0;

        return;
    }

    if (delay > 1000) {

        attackTimeout = setTimeout(
            scheduleAttack,
            Math.min(delay - 500, 1000)
        );

        return;
    }

    attackTimeout = setTimeout(() => {

        triggerAttack();

        localStorage.removeItem(STORAGE_KEY);

        attackTimeStr = '';
        attackTimestampMs = 0;

    }, delay);
}











function init() {

    const stored = localStorage.getItem(STORAGE_KEY);

if (stored) {

    const parsed = parseTimeString(stored);

    if (
        parsed &&
        parsed > unsafeWindow.Timing.getCurrentServerTime()
    ) {

        attackTimeStr = stored;
        attackTimestampMs = parsed + SEND_OFFSET;

        scheduleAttack();

    } else {

        localStorage.removeItem(STORAGE_KEY);

        attackTimeStr = '';
        attackTimestampMs = 0;
    }
}

}

init();
createGearButton();

})();
