    document.body.appendChild(overlay);
overlay.style.cursor = 'grab';





const attackInput =
    document.getElementById('attackTimeInput');

attackInput.addEventListener('input', e => {

    let value =
        e.target.value.replace(/[^0-9:]/g, '');

    value =
        value.replace(/:/g, '');

    if (value.length > 9) {
        value = value.slice(0, 9);
    }

let formatted = '';

if (value.length >= 1)
    formatted += value.slice(0, 2);

if (value.length >= 2)
    formatted += ':';

if (value.length >= 3)
    formatted += value.slice(2, 4);

if (value.length >= 4)
    formatted += ':';

if (value.length >= 5)
    formatted += value.slice(4, 6);

if (value.length >= 6)
    formatted += ':';

if (value.length >= 7)
    formatted += value.slice(6, 9);

    e.target.value = formatted;
});





let isDragging = false;
let dragX = 0;
let dragY = 0;

overlay.addEventListener('mousedown', e => {

    if (
        e.target.tagName === 'INPUT' ||
        e.target.tagName === 'BUTTON'
    ) return;

const rect = overlay.getBoundingClientRect();

overlay.style.left = rect.left + 'px';
overlay.style.top = rect.top + 'px';
overlay.style.transform = 'none';

    isDragging = true;
overlay.style.cursor = 'grabbing';

    dragX = e.clientX - overlay.offsetLeft;
    dragY = e.clientY - overlay.offsetTop;
});

document.addEventListener('mousemove', e => {

    if (!isDragging) return;

    let left = e.clientX - dragX;
    let top = e.clientY - dragY;

    const maxLeft =
        window.innerWidth -
        overlay.offsetWidth;

    const maxTop =
        window.innerHeight -
        overlay.offsetHeight;

    left = Math.max(
        0,
        Math.min(left, maxLeft)
    );

    top = Math.max(
        0,
        Math.min(top, maxTop)
    );

    overlay.style.left = left + 'px';
    overlay.style.top = top + 'px';
    overlay.style.transform = 'none';
});

document.addEventListener('mouseup', () => {
    isDragging = false;
 overlay.style.cursor = 'grab';
});

    document
        .getElementById('saveTimeBtn')
        .addEventListener('click', () => {

            const val =
                document
                    .getElementById('attackTimeInput')
                    .value
                    .trim();

            const parsed =
                parseTimeString(val);

            if (parsed === null) {
UI.ErrorMessage(
    'Helyes formátum: óra:perc:másodperc:ezred. Példa: 20:39:18:500',
    5000
);
                return;
            }

            localStorage.setItem(
                STORAGE_KEY,
                val
            );

            attackTimeStr = val;
            attackTimestampMs = parsed + SEND_OFFSET;
scheduleAttack();


UI.SuccessMessage(
    'Idő mentve: ' + val,
    4000
);

overlay.remove();

        });

    document
        .getElementById('closeHUDBtn')
        .addEventListener('click', () => {
            overlay.remove();
