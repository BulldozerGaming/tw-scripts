(function () {
'use strict';


if (
    game_data.screen !== 'place' ||
    !location.href.includes('try=confirm')
) {

    localStorage.removeItem('crytek_attack_time');

    return;
}





const STORAGE_KEY = 'crytek_attack_time';

let attackTimeStr = localStorage.getItem(STORAGE_KEY) || '';
let attackTimestampMs = 0;
let attackTimeout = null;

const SEND_OFFSET = 50;

function parseTimeString(timeStr) {

    const parts = timeStr.trim().split(':');

    if (parts.length !== 4) return null;

    const [h, m, s, ms] = parts.map(Number);

    const serverNow =
        new Date(
            unsafeWindow.Timing.getCurrentServerTime()
        );

    const target =
        new Date(
            serverNow.getFullYear(),
            serverNow.getMonth(),
            serverNow.getDate(),
            h,
            m,
            s,
            ms
        );

    let timestamp = target.getTime();

    if (timestamp < unsafeWindow.Timing.getCurrentServerTime()) {
        timestamp += 86400000;
    }

    return timestamp;
}

