// @match        https://*.klanhaboru.hu/game.php*
// @grant        none
// @require      https://cdn.jsdelivr.net/npm/exceljs/dist/exceljs.min.js
// @require      https://cdn.jsdelivr.net/npm/file-saver/dist/FileSaver.min.js
// ==/UserScript==

(function(){

'use strict';

const params=new URLSearchParams(location.search);

if(
game_data.screen!=="ally"||
params.get("mode")!=="members"
)return;

const UNIT_NAMES={

spear:'Lándzsás',
sword:'Kardforgató',
axe:'Bárdos',
archer:'Íjász',
spy:'Kém',

light:'Könnyűlovas',
marcher:'Lovasíjász',
heavy:'Nehézlovas',

ram:'Kos',
catapult:'Katapult',

knight:'Lovag',
snob:'Nemes'

};

/* ================================= */

function getPlayers(){

const map=new Map();

$('a[href*="info_player"]').each(function(){

const href=
$(this).attr(
'href'
);

const id=
href.match(
/id=(\d+)/
)?.[1];

if(!id)
return;

map.set(
id,
{

id,

name:
$(this)
.text()
.trim()

}

);

});

return [

...map.values()

]

.sort(
(a,b)=>

a.name.localeCompare(
b.name,
'hu'
)

);

}

/* ================================= */

function parseUnits(table){

const units=[];

table.querySelectorAll(
'th img'
).forEach(img=>{

const m=
img.src.match(
/unit_(.*?)\./
);

if(
!m||
m[1]==='militia'
)
return;

units.push(
m[1]
);

});

return units;

}

function villageInfo(text){

const coord=
text.match(
/\d+\|\d+/
)?.[0];

if(!coord)
return null;

return{

coord,

name:
text.trim()

};

}

/* ================================= */

async function fetchHtml(url){

return await $.get(url);

}

/* ================================= */

async function collect(mode,players,btn){

const rows=[];

for(
let i=0;
i<players.length;
i++
){

btn.innerText=

`${mode==="members_troops"?'Csapatok':'Védekezés'} ${i+1}/${players.length}`;

const p=
players[i];

const html=

await fetchHtml(

`${location.origin}/game.php?village=${game_data.village.id}&screen=ally&mode=${mode}&player_id=${p.id}`

);

const doc=
new DOMParser()
.parseFromString(
html,
'text/html'
);

const table=

[...doc.querySelectorAll(
'table.vis'
)]

.find(
t=>
t.innerText.includes(
'Falu'
)
);

if(!table)
continue;

const units=
parseUnits(
table
);

const trs=[
...table.querySelectorAll(
'tr'
)
];


for(
let x=0;
x<trs.length;
x++
){

const troopOffset=

mode==='members_defense'

?3

:2;

const td=
[
...trs[x]
.querySelectorAll(
'td'
)
];

if(
td.length<3
)
continue;

const village=
villageInfo(
td[0].innerText
);

if(!village)
continue;

const row=[

p.name,

village.name,

village.coord

];

if(
mode==='members_defense'
){

row.push(
'Faluban'
);

}

units.forEach(
(unit,index)=>{

row.push(

parseInt(

(
td[
troopOffset+index
]

?.innerText

||'0'

)

.replace(
/\./g,
'')

)||0

);

});


rows.push(
row
);

if(
mode!=='members_defense'
)
continue;

const next=
trs[x+1];

if(!next)
continue;

const td2=
[
...next.querySelectorAll(
'td'
)
];

const transit=[

p.name,

village.name,

village.coord,

'Úton'

];

const startIndex=
td2.length-units.length-1;

units.forEach(
(unit,index)=>{

transit.push(

parseInt(

(
td2[
startIndex+index
]

?.innerText

||'0'

)

.replace(
/\./g,
'')

)||0

);

});

rows.push(
transit);

x++;

}

}

return rows;

}

/* ================================= */

function styleCell(cell){

cell.border={

top:{style:'thin'},
bottom:{style:'thin'},
left:{style:'thin'},
right:{style:'thin'}

};

cell.alignment={

vertical:'middle',

horizontal:'left'

};

if(
cell.col===3
){

cell.alignment.horizontal=
'center';

}

/* egység oszlopok */

if(
cell.col>=4
){

cell.alignment.horizontal=
'right';

}

}

function styleRow(row){

row.eachCell(
c=>styleCell(c)
);

}

function autosize(ws){

ws.columns.forEach(col=>{

let maxPx=0;

col.eachCell(
{includeEmpty:true},
cell=>{

const text=

String(

cell.text ||

cell.value ||

''

);

let px=0;

for(
const ch of text
){

if(
/[WwMmÁÉŐŰÜÖÓÍ]/.test(ch)
){

px+=1.45;

}else if(
/[Iil1]/.test(ch)
){

px+=0.55;

}else{

px+=1;

}

}

if(
px>maxPx
){

maxPx=px;

}

});

col.width=

Math.min(

40,

Math.max(

maxPx+2,

5

)

);

});

}
/* ================================= */

function fillSheet(
ws,
headers,
data
){

ws.views=[{
state:'frozen',
ySplit:1
}];

ws.properties.outlineProperties={
summaryBelow:false
};

const header=
ws.addRow(headers);

header.font={
bold:true,
color:{argb:'FFFFFF'}
};

header.fill={
type:'pattern',
pattern:'solid',
fgColor:{argb:'8B5A2B'}
};

header.eachCell(c=>{

c.alignment={
horizontal:'center',
vertical:'middle'
};

c.border={
top:{style:'thin'},
bottom:{style:'thin'},
left:{style:'thin'},
right:{style:'thin'}
};

});

let current='';
let sums;

let playerDataStart=null;
let playerDataEnd=null;

function closePlayerBlock(){

if(
playerDataStart===null ||
playerDataEnd===null ||
playerDataEnd<playerDataStart
)return;

ws.mergeCells(

playerDataStart,
1,

playerDataEnd,
1

);

const c=

ws.getCell(
playerDataStart,
1
);

c.alignment={

horizontal:'center',
vertical:'middle'

};

}

function addSummary(){

if(!sums)return;

const rowData=
new Array(headers.length)
.fill('');

rowData[0]=current;

rowData[1]='Összesen';

const start=

headers.includes(
'Típus'
)

?4

:3;

for(
let i=start;
i<sums.length;
i++
){

rowData[i]=sums[i];

}

const row=
ws.addRow(
rowData
);

row.hidden=true;
row.outlineLevel=1;

row.fill={
type:'pattern',
pattern:'solid',
fgColor:{
argb:'C0504D'
}
};

row.font={
bold:true,
color:{
argb:'FFFFFF'
}
};

ws.mergeCells(

row.number,
2,

row.number,
3

);

row.getCell(
2
).alignment={

horizontal:'center',
vertical:'middle'

};

styleRow(
row
);

}

for(
let idx=0;
idx<data.length;
idx++
){

const r=data[idx];

if(
current!==r[0]
){

closePlayerBlock();

addSummary();

current=r[0];

const playerRow=

ws.addRow([
current
]);

playerRow.font={
bold:true
};

playerRow.fill={
type:'pattern',
pattern:'solid',
fgColor:{
argb:'DCC28A'
}
};

playerDataStart=
playerRow.number+1;

playerDataEnd=
null;

sums=
new Array(
headers.length
).fill(0);

}

const row=
ws.addRow(
r
);

row.hidden=true;

row.outlineLevel=1;

styleRow(
row
);

/* player merge content */

if(
playerDataEnd===null
){

row.getCell(1).value=r[0];

}else{

row.getCell(1).value='';

}

playerDataEnd=
row.number;

/* defense merge */

if(
headers.includes(
'Típus'
)
){

const prev=
data[idx-1];

const sameVillage=

prev &&

prev[0]===r[0] &&

prev[1]===r[1] &&

prev[2]===r[2];

if(
sameVillage
){

row.getCell(2).value='';
row.getCell(3).value='';

ws.mergeCells(

row.number-1,
2,

row.number,
2

);

ws.mergeCells(

row.number-1,
3,

row.number,
3

);

}

}

const start=

headers.includes(
'Típus'
)

?4

:3;

for(
let i=start;
i<r.length;
i++
){

sums[i]+=r[i];

}

}

closePlayerBlock();

addSummary();

ws.eachRow(row=>{

row.eachCell(cell=>{

if(
typeof cell.value===
'number'
){

cell.numFmt=
'# ##0';

}

});

});

autosize(
ws
);

}

/* ================================= */

async function exportExcel(
troops,
defense
){

const wb=
new ExcelJS.Workbook();

const troopSheet=

wb.addWorksheet(
'Csapatok',
{
properties:{
outlineLevelRow:1
}
}
);

const defenseSheet=

wb.addWorksheet(
'Védekezés',
{
properties:{
outlineLevelRow:1
}
}
);

fillSheet(

troopSheet,

[
'Játékos',
'Falu',
'Koordináta',

...Object.values(
UNIT_NAMES
)

],

troops

);

fillSheet(

defenseSheet,

[
'Játékos',
'Falu',
'Koordináta',
'Típus',

...Object.values(
UNIT_NAMES
)

],

defense

);

const buffer=

await wb.xlsx
.writeBuffer();

saveAs(

new Blob(
[buffer]
),

'Bulldozer_Klan_Export.xlsx'

);

}










