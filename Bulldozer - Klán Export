function makeDraggable(
el,
handle
){

let offsetX=0;
let offsetY=0;

handle.onmousedown=start;

function start(e){

e.preventDefault();

const rect=
el.getBoundingClientRect();

if(
el.dataset.centered!=='0'
){

el.style.transform='none';

el.style.left=
rect.left+'px';

el.style.top=
rect.top+'px';

el.dataset.centered='0';

}

offsetX=
e.clientX-rect.left;

offsetY=
e.clientY-rect.top;

document.onmousemove=
move;

document.onmouseup=
stop;

}

function move(e){

const rect=
el.getBoundingClientRect();

let left=
e.clientX-offsetX;

let top=
e.clientY-offsetY;

left=Math.max(
0,
Math.min(
window.innerWidth-rect.width,
left
)
);

top=Math.max(
0,
Math.min(
window.innerHeight-rect.height,
top
)
);

el.style.left=
left+'px';

el.style.top=
top+'px';

}

function stop(){

document.onmousemove=
null;

document.onmouseup=
null;

}

}















/* ================================= */

async function start(){

const btn=
document.getElementById(
'bdExport'
);

const old=
btn.innerText;

btn.style.pointerEvents=
'none';

const players=
getPlayers();

const troops=
await collect(
'members_troops',
players,
btn
);

const defense=
await collect(
'members_defense',
players,
btn
);

btn.innerText=
'Excel';

await exportExcel(
troops,
defense
);

btn.innerText=
old;

btn.style.pointerEvents=
'';

}

function initButtons(){

const row=

document.querySelector(
'#ally_content table.vis.modemenu tr'
);

if(
!row ||
document.getElementById(
'bdExport'
)
)
return;

row.insertAdjacentHTML(

'beforeend',

`
<td>
<a href="#" id="bdExport">
<b>Export</b>
</a>
</td>

<td>
<a href="#" id="bdInfo">
<b>Infó</b>
</a>
</td>
`

);

$('#bdExport').on(
'click',
e=>{

e.preventDefault();

start();

}
);

$('#bdInfo').on(
'click',
e=>{

e.preventDefault();

openInfoHud();

}
);

}

new MutationObserver(
initButtons
).observe(
document.body,
{
childList:true,
subtree:true
}
);

initButtons();








})();
