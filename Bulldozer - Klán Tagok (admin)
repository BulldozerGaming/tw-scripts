">

    <span style="
        font-weight:bold;
        color:#555;
    ">
        By
    </span>

    <span style="
        font-weight:bold;
        color:#8b0000;
    ">
        Crytek
    </span>

</div>

    </div>

`);

    let url =

        `${location.origin}` +
        `/game.php?village=${game_data.village.id}` +
        `&screen=ally` +
        `&mode=members_troops` +
        `&player_id=${player.id}`;

    let html =
        await fetchPage(url);

    let doc =
        new DOMParser()
        .parseFromString(
            html,
            'text/html'
        );

    let table = null;

    doc.querySelectorAll('.vis')
        .forEach(t => {

            if (
                t.innerText.includes('Falu') &&
                t.innerText.includes('Pont')
            ) {
                table = t;
            }
        });

    if (!table) {
        return;
    }

    table.querySelectorAll('tr')
        .forEach(row => {

            let cols =
                row.querySelectorAll('td');

if (cols.length < 5) {
    return;
}

            let village =
                cols[0].innerHTML;

            if (!village) {
                return;
            }

let unitIndex =
    getUnitIndexes(table);


let units = {

    axe:
        getCol(
            cols,
            unitIndex.axe
        ),

    spy:
        getCol(
            cols,
            unitIndex.spy
        ),

    light:
        getCol(
            cols,
            unitIndex.light
        ),

    marcher:
        getCol(
            cols,
            unitIndex.marcher
        ),

    ram:
        getCol(
            cols,
            unitIndex.ram
        ),

    catapult:
        getCol(
            cols,
            unitIndex.catapult
        ),

    knight:
        getCol(
            cols,
            unitIndex.knight
        ),

    snob:
        getCol(
            cols,
            unitIndex.snob
        )
};

let pop = (

    units.axe * 1 +
    units.spy * 2 +
    units.light * 4 +
    units.marcher * 5 +
    units.ram * 5 +
    units.catapult * 8 +
    units.knight * 10 +
    units.snob * 100
);

let category = null;

if (pop >= 18000) {
    category = 'Nuke';
}
else if (pop >= 15000) {
    category = '3/4 Nuke';
}
else if (pop >= 10000) {
    category = '1/2 Nuke';
}
else if (pop >= 5000) {
    category = '1/4 Nuke';
}

if (!category) {
    return;
}

result[category].push({

    player:
        player.name,

    village,

    units,

    pop
});

        });
}

