unitIndexes.spear=index;

if(src.includes('unit_sword'))
unitIndexes.sword=index;

if(src.includes('unit_archer'))
unitIndexes.archer=index;

if(src.includes('unit_heavy'))
unitIndexes.heavy=index;

if(src.includes('unit_knight'))
unitIndexes.knight=index;

});

let support={

spear:0,
sword:0,
archer:0,
heavy:0,
knight:0

};

rows.forEach((row,i)=>{

if(i===0)return;

let cols=
row.querySelectorAll('td');

if(!cols.length)return;

let ownVillage=
row.innerText.includes(
'Ebből a faluból'
);

if(ownVillage){
return;
}

support.spear+=
num(cols[
unitIndexes.spear
]?.innerText);

support.sword+=
num(cols[
unitIndexes.sword
]?.innerText);

support.archer+=
num(cols[
unitIndexes.archer
]?.innerText);

support.heavy+=
num(cols[
unitIndexes.heavy
]?.innerText);

support.knight+=
num(cols[
unitIndexes.knight
]?.innerText);

});

return support;

}catch(e){

return null;

}

}

