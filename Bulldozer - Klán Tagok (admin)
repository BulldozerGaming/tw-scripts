// =========================================
// REQUEST
// =========================================

async function fetchPage(url) {

    return new Promise(resolve => {

        GM_xmlhttpRequest({

            method: 'GET',
            url,

            onload: function (r) {

                resolve(r.responseText);
            }
        });

    });
}

