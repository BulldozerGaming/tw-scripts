function getUnitIndexes(table) {

    let indexes = {};

    let headers =
        table.querySelectorAll('tr th');

    headers.forEach((th, index) => {

        let img =
            th.querySelector('img');

        if (!img) {
            return;
        }

        let src =
            img.src;

        if (src.includes('unit_spear')) {
            indexes.spear = index;
        }

        if (src.includes('unit_sword')) {
            indexes.sword = index;
        }

        if (src.includes('unit_axe')) {
            indexes.axe = index;
        }

        if (src.includes('unit_archer')) {
            indexes.archer = index;
        }

        if (src.includes('unit_spy')) {
            indexes.spy = index;
        }

        if (src.includes('unit_light')) {
            indexes.light = index;
        }

        if (src.includes('unit_marcher')) {
            indexes.marcher = index;
        }

        if (src.includes('unit_heavy')) {
            indexes.heavy = index;
        }

        if (src.includes('unit_ram')) {
            indexes.ram = index;
        }

        if (src.includes('unit_catapult')) {
            indexes.catapult = index;
        }

        if (src.includes('unit_knight')) {
            indexes.knight = index;
        }

        if (src.includes('unit_snob')) {
            indexes.snob = index;
        }

        if (src.includes('unit_militia')) {
            indexes.militia = index;
        }
    });

    return indexes;
}

function num(v) {

    v = String(v)
        .replace(/\./g, '')
        .trim();

    if (
        v === '?' ||
        v === ''
    ) {
        return 0;
    }

    return parseInt(v) || 0;
}

function getCol(cols, index) {

    if (
        index === undefined ||
        index === null ||
        index < 0
    ) {
        return 0;
    }

    return num(
        cols?.[index]?.innerText
    );
}

