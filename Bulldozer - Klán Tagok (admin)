// =========================================

async function start() {

result = {

'Nuke':[],
'3/4 Nuke':[],
'1/2 Nuke':[],
'1/4 Nuke':[]

};

clanTotalSnobs = 0;

const BATCH=6;

for(
let i=0;
i<players.length;
i+=BATCH
){

await Promise.all(

players
.slice(
i,
i+BATCH
)

.map(
scanPlayer
)

);

}

render();

}

