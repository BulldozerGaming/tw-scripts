    spear: 0,
    sword: 0,
    archer: 0,
    heavy: 0,
    knight: 0
};

let travelingDefense = {

    spear: 0,
    sword: 0,
    archer: 0,
    heavy: 0,
    knight: 0
};

function calcDefense(units) {

    return (

        units.spear * 1 +
        units.sword * 1 +
        units.archer * 1 +
        units.heavy * 6 +
        units.knight * 10
    );
}

function defenseCategory(pop) {

    if (pop >= 18000) {
        return 'VF';
    }

    if (pop >= 15000) {
        return '3/4 VF';
    }

    if (pop >= 10000) {
        return '1/2 VF';
    }

    if (pop >= 5000) {
        return '1/4 VF';
    }

    if (pop >= 3000) {
        return '1/6 VF';
    }

    if (pop >= 1000) {
        return '1/20 VF';
    }

    return 'Maradék';
}

