$(document).on(

"click",

"#plannerCalc",

function(){

const targets=
parseCoords(
$("#plannerTargets").val()
);

const nukes=
parseCoords(
$("#plannerNukes").val()
);

const snobs=
parseCoords(
$("#plannerSnobs").val()
);

$("#plannerTargets").val(
targets.join(" ")
);

$("#plannerNukes").val(
nukes.join(" ")
);

$("#plannerSnobs").val(
snobs.join(" ")
);

const nukePer=
parseInt(
$("#plannerNukeCount").val()
)||1;

const snobPer=
parseInt(
$("#plannerSnobCount").val()
)||1;

/* =====================
   VALIDÁLÁS
===================== */

const messages=[];

/* idő */

const arrivalRaw=
$("#arrivalTime")
.val()
.trim();

if(!arrivalRaw){

UI.ErrorMessage(
"Add meg a csapódási időt."
);

return;

}

const parts = arrivalRaw.match(
/(\d+)-(\d+)-(\d+)\s+(\d+):(\d+):(\d+)/
);

if(!parts){

UI.ErrorMessage(
"A Csapódási idő rossz formátumú."
);

return;

}

const arrival = new Date(
parts[1],
parts[2]-1,
parts[3],
parts[4],
parts[5],
parts[6]
);

if(
isNaN(
arrival.getTime()
)
){

UI.ErrorMessage(
"A Csapódási idő rossz formátumban van megadva."
);

return;

}

/* célpont */

if(
targets.length===0
){

UI.ErrorMessage(
"Helyezz el koordinátát a Célpont mezőbe."
);

return;

}

/* nincs forrás */

if(
nukes.length===0 &&
snobs.length===0
){

UI.ErrorMessage(
"Helyezz el koordinátát a Nemes vagy Nuke mezőbe."
);

return;

}

/* kevés nuke */

if(

nukes.length>0 &&

nukes.length <
(targets.length*nukePer)

){

messages.push(

`Kevés Nuke koordináta (${nukes.length}/${targets.length*nukePer}) - Részleges tervezés`

);

}

/* kevés nemes */

if(

snobs.length>0 &&

snobs.length <
(targets.length*snobPer)

){

messages.push(

`Kevés Nemes koordináta (${snobs.length}/${targets.length*snobPer}) - Részleges tervezés`

);

}

/* összes üzenet */

if(messages.length){

UI.InfoMessage(

messages.join("<br>")

);

}

let output=[];


/* NUKE OPTIMALIZER */

let allNukes=[];

for(const target of targets){

for(const from of nukes){

allNukes.push({

from,
target,

time:

arrival.getTime()

-

(

plannerDistance(
from,
target
)

*

window.RAM_SPEED

*

60000

),

type:"NUKE"

});

}

}

allNukes.sort(
(a,b)=>a.time-b.time
);










const requiredNukes =
Math.min(
nukes.length,
targets.length*nukePer
);

const usedSources =
new Set();

const targetCount =
Object.fromEntries(
targets.map(
t=>[t,0]
)
);

const picked=[];

for(const attack of allNukes){

if(
picked.length>=requiredNukes
){
break;
}

if(
usedSources.has(
attack.from
)
){
continue;
}

if(
targetCount[
attack.target
]>=nukePer
){
continue;
}

picked.push(
attack
);

usedSources.add(
attack.from
);

targetCount[
attack.target
]++;

}

output.push(
...picked
);


























/* NOBLE OPTIMIZER */

if(
snobs.length
){

let allSnobs=[];

for(const target of targets){

for(const from of snobs){

allSnobs.push({

from,
target,

time:

arrival.getTime()

-

(

plannerDistance(
from,
target
)

*

window.SNOB_SPEED

*

60000

),

type:"NEMES"

});

}

}

allSnobs.sort(
(a,b)=>a.time-b.time
);






const requiredSnobs =
Math.min(
snobs.length,
targets.length*snobPer
);

const usedSources =
new Set();

const targetCount =
Object.fromEntries(
targets.map(
t=>[t,0]
)
);

const picked=[];

for(const attack of allSnobs){

if(
picked.length>=requiredSnobs
){
break;
}

if(
usedSources.has(
attack.from
)
){
continue;
}

if(
targetCount[
attack.target
]>=snobPer
){
continue;
}

picked.push(
attack
);

usedSources.add(
attack.from
);

targetCount[
attack.target
]++;

}

output.push(
...picked
);


}






output.sort(
(a,b)=>
a.time-b.time
);

const arrivalText=
$("#arrivalTime").val();





const formatted =

`[size=12][b]Csapódás: [color=#0000ff]${arrivalText}[/color][/b][/size]

[size=11][b]Indítások[/b][/size]

[table]
[**]Indító[||]Célpont[||]Indítás[||][img]${WATCH_ICON}[/img][/**]
`

+

output.map((x,i)=>{

const d=
new Date(
x.time
);

const pad=n=>
String(n).padStart(2,"0");

const launch=

pad(d.getHours())+
":"+
pad(d.getMinutes())+
":"+
pad(d.getSeconds());


const fromId=
getVillageId(
x.from
);

const targetId=
getVillageId(
x.target
);

const attackIcon =

x.type==="NUKE"

? NUKE_ICON

: SNOB_ICON;

return(

`[*][coord]${x.from}[/coord]`+

`[|][coord]${x.target}[/coord]`+

`[|][b][color=green]${launch}[/color][/b]`+

`[|][url=${PLANNER_BASE_URL}/game.php?village=${fromId}&screen=place&target=${targetId}`+

`&crytekAuto=1`+

`&crytekTarget=${encodeURIComponent(x.target)}`+

`]`+

`[img]${attackIcon}[/img]`+

`[/url]`

);

}).join("\n")

+

`[/table]`;







$("#plannerOutput").val(
formatted
);

}); // <-- EZ ZÁRJA LE A plannerCalc clicket

