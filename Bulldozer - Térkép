        counts.push(troops['spy'], troops['light']);
        if (archersEnabled) counts.push(troops['marcher']);
        counts.push(troops['heavy'], troops['ram'], troops['catapult']);
        if (paladinEnabled) counts.push(troops['knight']);
        counts.push(troops['snob']);
