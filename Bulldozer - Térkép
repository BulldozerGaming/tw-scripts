$(document).on(
"click",
".plannerReset",
function(){

const type=
$(this).data(
"reset"
);

const now=
new Date();

const pad=n=>
String(n).padStart(
2,
"0"
);

if(type==="arrival"){

$("#arrivalTime").val(

now.getFullYear()+"-"+
pad(now.getMonth()+1)+"-"+
pad(now.getDate())+" "+
pad(now.getHours())+":"+
pad(now.getMinutes())+":"+
pad(now.getSeconds())

);

}

if(type==="targets"){

$("#plannerTargets").val("");

}

if(type==="nukes"){

$("#plannerNukes").val("");

$("#plannerNukeCount").val(1);

}

if(type==="snobs"){

$("#plannerSnobs").val("");

$("#plannerSnobCount").val(1);

}

});






