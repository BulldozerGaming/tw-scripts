/* ===========================
   START PARSE DEFENSE UNITS FUNCTION
=========================== */

function parseDefenseUnits(html){

const doc=$($.parseHTML(html));

const tables=

doc.find(
"#ally_content table.vis"
);

const table=

tables.filter(function(){

return $(this)

.find(
"img[src*='unit_']"
)

.length>5;

}).first();

if(!table.length){

console.log(
"Defense table not found"
);

return [];
}

const rows=
table.find("tr");

const result=[];

rows.each(function(){

const tds=

$(this)

.find("td");

if(
tds.length<2
)
return;


/* koordináta öröklés */

let coord=

null;

const rawCoord=

tds.eq(0)

.text()

.trim();

const match=

rawCoord.match(

/(\d+\|\d+)/

);

if(match){

coord=

match[1];

window.frontlineLastDefenseCoord=
coord;

}else{

coord=

window.frontlineLastDefenseCoord;

}

if(
!coord
)
return;
const whereIndex=

match

?

2

:

0;

const where=

tds.eq(
whereIndex
)

.text()

.replace(/\s+/g," ")

.trim()

.toLowerCase();

const normalizedWhere=

where

.normalize(
"NFD"
)

.replace(

/[\u0300-\u036f]/g,

""

);

if(

!normalizedWhere.includes(
"faluban"
)

&&

!normalizedWhere.includes(
"uton"
)

){

return;

}
const units=[];

tds.slice(

match

?

3

:

1

).each(function(){

units.push(
parseInt(
$(this)
.text()
.replace(/\./g,"")
.trim()
)||0
);

});



const expectedUnits=

game_data.units.length+

1;

while(

units.length<

expectedUnits

){

units.push(

where.includes(
"fal"
)

?

0

:

""

);

}

result.push({
coord,
where,
units
});



});

return result;

}

/* ===========================
   END PARSE DEFENSE UNITS FUNCTION
=========================== */





