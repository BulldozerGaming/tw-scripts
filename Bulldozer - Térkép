function enableCoordPicker(){


if(
!window.coordSpawnHooked
){

window.coordSpawnHooked=true;

const oldSpawn=
TWMap.mapHandler.spawnSector;

TWMap.mapHandler.spawnSector=
function(data,sector){

oldSpawn.call(
this,
data,
sector
);

setTimeout(
drawVillageSelection,
0
);

};

}

if(window.coordPickerInitialized)
return;

window.coordPickerInitialized=true;

window.coordPickerEnabled=false;

/* EREDETI MAP CLICK ELMENTÉS */

window.coordOldClick =
TWMap.mapHandler.onClick;

/* SAJÁT CLICK HANDLER */

TWMap.mapHandler.onClick=
function(x,y,event){

if(!window.coordPickerEnabled){

return window.coordOldClick
? window.coordOldClick(
x,
y,
event
)
: true;

}

const coord=
x+"|"+y;

const village=
TWMap.villages[
(x*1000)+y
];

if(!village)
return false;

const idx=
window.selectedVillages
.indexOf(coord);

if(idx>-1){

window.selectedVillages.splice(
idx,
1
);

}else{

window.selectedVillages.push(
coord
);

}

updateCoordInput();

drawVillageSelection();

/* KH popup tiltás */

return false;

};

}

