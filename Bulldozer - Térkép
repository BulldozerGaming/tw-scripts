var Calculator = {

getStackColor(stack){

stack/=1000;

if(stack<1)
return "rgba(90,90,90,0.55)";

if(stack<3)
return "rgba(0,0,0,0.55)";

if(stack<5)
return "rgba(0,180,0,0.55)";

if(stack<10)
return "rgba(0,255,255,0.55)";

if(stack<15)
return "rgba(255,255,0,0.60)";

if(stack<20)
return "rgba(255,140,0,0.60)";

if(stack<30)
return "rgba(255,90,90,0.60)";

if(stack<40)
return "rgba(220,0,0,0.65)";

return "rgba(0,120,255,0.65)";

}

};

var MapRenderer = {
    makeMap() {
        if (mapOverlay.mapHandler._spawnSector) {
            //exists already, don't recreate
        }
        else {
            //doesn't exist yet
            mapOverlay.mapHandler._spawnSector = mapOverlay.mapHandler.spawnSector;
        }
        mapOverlay.mapHandler.spawnSector = (data, sector) => {
            mapOverlay.mapHandler._spawnSector(data, sector);
            this.renderSector(data, sector);
        };
        mapOverlay.reload();

setTimeout(
drawVillageSelection,
100
);
    },

    renderSector(data, sector) {
        // Main map canvas
        const beginX = sector.x - data.x;
        const endX = beginX + mapOverlay.mapSubSectorSize;
        const beginY = sector.y - data.y;
        const endY = beginY + mapOverlay.mapSubSectorSize;
        for (let x in data.tiles) {
            x = parseInt(x, 10);
            if (x < beginX || x >= endX) continue;
            for (let y in data.tiles[x]) {
                y = parseInt(y, 10);
                if (y < beginY || y >= endY) continue;
                const v = mapOverlay.villages[(data.x + x) * 1000 + (data.y + y)];
                if (v) {
                    let el = $('#mapOverlay_canvas_' + sector.x + '_' + sector.y);
                    if (!el.length) {
                        const canvas = document.createElement('canvas');
                        canvas.style.position = 'absolute';
                        canvas.width = mapOverlay.map.scale[0] * mapOverlay.map.sectorSize;
                        canvas.height = mapOverlay.map.scale[1] * mapOverlay.map.sectorSize;
                        canvas.style.zIndex = 10;
                        canvas.className = 'mapOverlay_map_canvas';
                        canvas.id = 'mapOverlay_canvas_' + sector.x + '_' + sector.y;
                        const ctx = canvas.getContext('2d');
                        const st_pixel = mapOverlay.map.pixelByCoord(sector.x, sector.y);

                        targetData.forEach(element => {
                            const t = element.coord.split('|');
                            const originXY = mapOverlay.map.pixelByCoord(t[0], t[1]);
                            const originX = (originXY[0] - st_pixel[0]) + mapOverlay.tileSize[0] / 2;
                            const originY = (originXY[1] - st_pixel[1]) + mapOverlay.tileSize[1] / 2;
                            if (t[0] >= sector.x && t[0] < sector.x + 5 && t[1] >= sector.y && t[1] < sector.y + 5) {
      const totalColor =
Calculator.getStackColor(
element.totalStack
);

                                if (element.incomingAttacks > 0){

this.iconOnMap(
images[0],
canvas,
originX + 7,
originY - 12,
15
);

this.textOnMap(
element.incomingAttacks,
ctx,
originX + 20,
originY - 8,
"white",
"10px Arial"
);

}

this.textWithBackground(
Math.floor(element.totalStack/1000)+"k",
ctx,
originX-2,
originY+14,
totalColor
);
                            }


                        });


                        sector.appendElement(canvas, 0, 0);


                    }
                }
            }
        }
    },

    drawMapTowers(canvas, sector, x, y, wtLevel, color, opacity) {
        const ctx = canvas.getContext('2d');
        ctx.lineWidth = 2;
        ctx.fillStyle = color;
        ctx.globalAlpha = opacity;
        const wtr = WATCHTOWER_RADIUS[wtLevel - 1];
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.ellipse(x, y, wtr * TWMap.map.scale[0], wtr * TWMap.map.scale[1], 0, 0, 2 * Math.PI);
        ctx.stroke();
        ctx.fill();
        ctx.closePath();
        ctx.beginPath();
        ctx.strokeStyle = "#000000";
        ctx.moveTo(x - 6, y - 6);
        ctx.lineTo(x + 6, y + 6);
        ctx.moveTo(x + 6, y - 6);
        ctx.lineTo(x - 6, y + 6);
        ctx.stroke();
        ctx.closePath();
        ctx.globalAlpha = 1;
    },

    drawTopoTowers(canvas, sector, x, y, wtLevel, color, opacity) {
        const ctx = canvas.getContext('2d');
        ctx.lineWidth = 1;
        ctx.fillStyle = color;
        ctx.globalAlpha = opacity;
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.arc(x, y, WATCHTOWER_RADIUS[wtLevel - 1] * 5, 0, 2 * Math.PI);
        ctx.stroke();
        ctx.fill();
        ctx.closePath();
        ctx.beginPath();
        ctx.strokeStyle = "#000000";
        ctx.moveTo(x - 2, y - 2);
        ctx.lineTo(x + 2, y + 2);
        ctx.moveTo(x + 2, y - 2);
        ctx.lineTo(x - 2, y + 2);
        ctx.stroke();
        ctx.closePath();
        ctx.globalAlpha = 1;
    },

    drawLeftTriangle(canvas, x, y, color) {
        const ctx = canvas.getContext("2d");
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.moveTo(x - tileWidthX / 2, y - tileWidthY / 2);
        ctx.lineTo(x + tileWidthX / 2, y - tileWidthY / 2);
        ctx.lineTo(x - tileWidthX / 2, y + tileWidthY / 2);
        ctx.fill();
    },

    drawRightTriangle(canvas, x, y, color) {
        const ctx = canvas.getContext("2d");
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.moveTo(x + tileWidthX / 2, y - tileWidthY / 2);
        ctx.lineTo(x + tileWidthX / 2, y + tileWidthY / 2);
        ctx.lineTo(x - tileWidthX / 2, y + tileWidthY / 2);
        ctx.fill();
    },

    iconOnMap(img, canvas, x, y, size) {
        canvas.getContext("2d").drawImage(img, x - size / 2, y - size / 2, size, size);
    },

    textOnMap(text, ctx, x, y, color, font) {
        ctx.font = font;
        ctx.fillStyle = color;
        ctx.textAlign = "center";
        ctx.save();
        ctx.strokeStyle = 'black';
        ctx.lineWidth = 4;
        ctx.lineJoin = "round";
        ctx.miterLimit = 1;
        ctx.strokeText(text, x, y);
        ctx.fillText(text, x, y);
        ctx.restore();
    },

textWithBackground(
text,
ctx,
x,
y,
bg
){

ctx.save();

ctx.font="bold 10px Arial";

ctx.textAlign="center";

ctx.textBaseline="middle";

const paddingX=5;
const paddingY=4;

const metrics=
ctx.measureText(text);

const textWidth=
metrics.width;

const ascent=
metrics.actualBoundingBoxAscent || 7;

const descent=
metrics.actualBoundingBoxDescent || 3;

const textHeight=
ascent+descent;

const boxWidth=
Math.ceil(
textWidth+(paddingX*2)
);

const boxHeight=
Math.ceil(
textHeight+(paddingY*2)
);

const lightBg=

bg.includes("255,255,0") ||
bg.includes("255,140,0") ||
bg.includes("0,255,255");

const textColor=
lightBg
? "black"
: "white";

const strokeColor=
lightBg
? "white"
: "black";

/* háttér */

ctx.fillStyle=bg;

const bgY=
Math.round(
y-boxHeight/2
)-1;

ctx.fillRect(

Math.round(
x-boxWidth/2
),

bgY,

boxWidth,

boxHeight

);

/* szöveg */

ctx.lineWidth=3;

ctx.strokeStyle=
strokeColor;

ctx.strokeText(
text,
x,
y
);

ctx.fillStyle=
textColor;

ctx.fillText(
text,
x,
y
);

ctx.restore();

},

    makeOutput(data) {
        $("#overwatch_info").remove();
        const coordinate = data.xy.toString().substring(0, 3) + "|" + data.xy.toString().substring(3, 6);
        const thisData = targetData.filter(coord => coord.coord === coordinate);
        if (thisData.length > 0) {
