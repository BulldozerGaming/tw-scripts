    drawMapTowers(canvas, sector, x, y, wtLevel, color, opacity) {
        const ctx = canvas.getContext('2d');
        ctx.lineWidth = 2;
        ctx.fillStyle = color;
        ctx.globalAlpha = opacity;
        const wtr = WATCHTOWER_RADIUS[wtLevel - 1];
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.ellipse(x, y, wtr * TWMap.map.scale[0], wtr * TWMap.map.scale[1], 0, 0, 2 * Math.PI);
        ctx.stroke();
        ctx.fill();
        ctx.closePath();
        ctx.beginPath();
        ctx.strokeStyle = "#000000";
        ctx.moveTo(x - 6, y - 6);
        ctx.lineTo(x + 6, y + 6);
        ctx.moveTo(x + 6, y - 6);
        ctx.lineTo(x - 6, y + 6);
        ctx.stroke();
        ctx.closePath();
        ctx.globalAlpha = 1;
    },

    drawTopoTowers(canvas, sector, x, y, wtLevel, color, opacity) {
        const ctx = canvas.getContext('2d');
        ctx.lineWidth = 1;
        ctx.fillStyle = color;
        ctx.globalAlpha = opacity;
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.arc(x, y, WATCHTOWER_RADIUS[wtLevel - 1] * 5, 0, 2 * Math.PI);
        ctx.stroke();
        ctx.fill();
        ctx.closePath();
        ctx.beginPath();
        ctx.strokeStyle = "#000000";
        ctx.moveTo(x - 2, y - 2);
        ctx.lineTo(x + 2, y + 2);
        ctx.moveTo(x + 2, y - 2);
        ctx.lineTo(x - 2, y + 2);
        ctx.stroke();
        ctx.closePath();
        ctx.globalAlpha = 1;
    },

    drawLeftTriangle(canvas, x, y, color) {
        const ctx = canvas.getContext("2d");
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.moveTo(x - tileWidthX / 2, y - tileWidthY / 2);
        ctx.lineTo(x + tileWidthX / 2, y - tileWidthY / 2);
        ctx.lineTo(x - tileWidthX / 2, y + tileWidthY / 2);
        ctx.fill();
    },

    drawRightTriangle(canvas, x, y, color) {
        const ctx = canvas.getContext("2d");
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.moveTo(x + tileWidthX / 2, y - tileWidthY / 2);
        ctx.lineTo(x + tileWidthX / 2, y + tileWidthY / 2);
        ctx.lineTo(x - tileWidthX / 2, y + tileWidthY / 2);
        ctx.fill();
    },

    iconOnMap(img, canvas, x, y, size) {
        canvas.getContext("2d").drawImage(img, x - size / 2, y - size / 2, size, size);
    },

    textOnMap(text, ctx, x, y, color, font) {
        ctx.font = font;
        ctx.fillStyle = color;
        ctx.textAlign = "center";
        ctx.save();
        ctx.strokeStyle = 'black';
        ctx.lineWidth = 4;
        ctx.lineJoin = "round";
        ctx.miterLimit = 1;
        ctx.strokeText(text, x, y);
        ctx.fillText(text, x, y);
        ctx.restore();
    },

textWithBackground(
text,
ctx,
x,
y,
bg
){

ctx.save();

ctx.font="bold 10px Arial";

ctx.textAlign="center";

ctx.textBaseline="middle";

const paddingX=5;
const paddingY=4;

const metrics=
ctx.measureText(text);

const textWidth=
metrics.width;

const ascent=
metrics.actualBoundingBoxAscent || 7;

const descent=
metrics.actualBoundingBoxDescent || 3;

const textHeight=
ascent+descent;

const boxWidth=
Math.ceil(
textWidth+(paddingX*2)
);

const boxHeight=
Math.ceil(
textHeight+(paddingY*2)
);

const lightBg=

bg.includes("255,255,0") ||
bg.includes("255,140,0") ||
bg.includes("0,255,255");

const textColor=
lightBg
? "black"
: "white";

const strokeColor=
lightBg
? "white"
: "black";

/* háttér */

ctx.fillStyle=bg;

const bgY=
Math.round(
y-boxHeight/2
)-1;

ctx.fillRect(

Math.round(
x-boxWidth/2
),

bgY,

boxWidth,

boxHeight

);

/* szöveg */

ctx.lineWidth=3;

ctx.strokeStyle=
strokeColor;

ctx.strokeText(
text,
x,
y
);

ctx.fillStyle=
textColor;

ctx.fillText(
text,
x,
y
);

ctx.restore();

},

