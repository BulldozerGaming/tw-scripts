/* ===========================
   START PARSE COORDS FUNCTION
=========================== */

function parseCoords(text){

const matches=
text.match(
/\d{1,3}\|\d{1,3}/g
);

if(!matches)
return [];

const seen=
Object.create(null);

return matches.filter(x=>{

if(seen[x])
return false;

seen[x]=1;

return true;

});

}

/* ===========================
   END PARSE COORDS FUNCTION
=========================== */





/* ===========================
   START COORD CACHE HELPERS
=========================== */

const coordCache=
Object.create(null);

function getCoordParts(coord){

if(coordCache[coord])
return coordCache[coord];

const parts=
coord.split("|");

return coordCache[coord]=[
parseInt(parts[0]),
parseInt(parts[1])
];

}

function plannerDistance(a,b){

const aa=
getCoordParts(a);

const bb=
getCoordParts(b);

const dx=
aa[0]-bb[0];

const dy=
aa[1]-bb[1];

return Math.sqrt(
dx*dx + dy*dy
);

}

/* ===========================
   END COORD CACHE HELPERS
=========================== */





