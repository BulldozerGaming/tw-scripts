localStorage.setItem(
"crytek_unit_speed",
unitSpeed
);

updateFrontlineSpeedInfo();

}

);

return;

}

const distance =
Math.max(
1,
parseFloat(
$("#frontlineDistance").val()
) || 4
);

const snobPerField =
35 / (
worldSpeed *
unitSpeed
);

const ramPerField =
30 / (
worldSpeed *
unitSpeed
);

function formatMinutes(mins){

const totalSeconds =
Math.round(
mins * 60
);

const hours =
Math.floor(
totalSeconds / 3600
);

const minutes =
Math.floor(
(totalSeconds % 3600) / 60
);

const seconds =
totalSeconds % 60;

if(hours <= 0){

return (

minutes +

":" +

String(seconds)
.padStart(
2,
"0"
)

);

}

return (

hours +

":" +

String(minutes)
.padStart(
2,
"0"
)

+

":"

+

String(seconds)
.padStart(
2,
"0"
)

);

}

$("#frontlineSnobText").text(

"Nemes " +

formatMinutes(
snobPerField
)

+

" perc / mező | "

+

formatMinutes(

snobPerField *
distance

)

);

$("#frontlineRamText").text(

"Kos " +

formatMinutes(
ramPerField
)

+

" perc / mező | "

+

formatMinutes(

ramPerField *
distance

)

);

}

