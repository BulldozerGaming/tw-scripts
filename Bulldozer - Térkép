const RAM_SPEED=30;
const SNOB_SPEED=35;

function parseCoords(text){

const matches=
text.match(
/\d{1,3}\|\d{1,3}/g
);

return matches
? [...new Set(matches)]
: [];

}

function plannerDistance(a,b){

const [ax,ay]=
a.split("|").map(Number);

const [bx,by]=
b.split("|").map(Number);

return Math.sqrt(

Math.pow(ax-bx,2)+
Math.pow(ay-by,2)

);

}

function calcLaunch(
arrival,
from,
to,
speed
){

const dist=
plannerDistance(
from,
to
);

return new Date(

arrival.getTime()

-

(dist*speed*60000)

);

}



$(document).on(

"click",

"#plannerCalc",

function(){

const targets=
parseCoords(
$("#plannerTargets").val()
);

const nukes=
parseCoords(
$("#plannerNukes").val()
);

const snobs=
parseCoords(
$("#plannerSnobs").val()
);

$("#plannerTargets").val(
targets.join(" ")
);

$("#plannerNukes").val(
nukes.join(" ")
);

$("#plannerSnobs").val(
snobs.join(" ")
);

const nukePer=
parseInt(
$("#plannerNukeCount").val()
)||1;

const snobPer=
parseInt(
$("#plannerSnobCount").val()
)||1;

/* =====================
   VALIDÁLÁS
===================== */

const messages=[];

/* idő */

const arrivalRaw=
$("#arrivalTime")
.val()
.trim();

if(!arrivalRaw){

UI.ErrorMessage(
"Add meg a csapódási időt."
);

return;

}

const arrival=
new Date(
arrivalRaw.replace(
" ",
"T"
)
);

if(
isNaN(
arrival.getTime()
)
){

UI.ErrorMessage(
"A Csapódási idő rossz formátumban van megadva."
);

return;

}

/* célpont */

if(
targets.length===0
){

UI.ErrorMessage(
"Helyezz el koordinátát a Célpont mezőbe."
);

return;

}

/* nincs forrás */

if(
nukes.length===0 &&
snobs.length===0
){

UI.ErrorMessage(
"Helyezz el koordinátát a Nemes vagy Nuke mezőbe."
);

return;

}

/* kevés nuke */

if(

nukes.length>0 &&

nukes.length <
(targets.length*nukePer)

){

messages.push(

`Kevés Nuke koordináta (${nukes.length}/${targets.length*nukePer}) - Részleges tervezés`

);

}

/* kevés nemes */

if(

snobs.length>0 &&

snobs.length <
(targets.length*snobPer)

){

messages.push(

`Kevés Nemes koordináta (${snobs.length}/${targets.length*snobPer}) - Részleges tervezés`

);

}

/* összes üzenet */

messages.forEach(
x=>UI.InfoMessage(x)
);

let output=[];


/* NUKE OPTIMALIZER */

let allNukes=[];

targets.forEach(target=>{

nukes.forEach(from=>{

const launch=

calcLaunch(
arrival,
from,
target,
RAM_SPEED
);

allNukes.push({

from,
target,

launch,

time:
launch.getTime(),

type:
"NUKE"

});

});

});

allNukes.sort(
(a,b)=>
a.time-b.time
);

let bestNuke=null;

function searchNuke(
current,
usedSources,
targetCount,
startIndex
){

const neededAssignments =
Math.min(
nukes.length,
targets.length*nukePer
);

const valid=

current.length >=
neededAssignments;

if(valid){

const times=
current
.map(
x=>x.time
)
.sort(
(a,b)=>a-b
);

const avg =
times.reduce(
(a,b)=>a+b,
0
)/times.length;

let spread=0;

times.forEach(t=>{

spread+=Math.abs(
t-avg
);

});

if(
!bestNuke ||
spread<
bestNuke.spread
){

bestNuke={

spread,

picked:
[...current]

};

}

return;

}

for(
let i=startIndex;
i<allNukes.length;
i++
){

const x=
allNukes[i];

if(
usedSources.has(
x.from
)
)
continue;

if(
targetCount[
x.target
]>=nukePer
)
continue;

usedSources.add(
x.from
);

targetCount[
x.target
]++;

current.push(x);

searchNuke(

current,
usedSources,
targetCount,
i+1

);

current.pop();

usedSources.delete(
x.from
);

targetCount[
x.target
]--;

}

}

searchNuke(

[],

new Set(),

Object.fromEntries(
targets.map(
t=>[t,0]
)
),

0

);
if(bestNuke){

output.push(
...bestNuke.picked
);

}


/* NOBLE OPTIMIZER */

if(
snobs.length
){

let allSnobs=[];

targets.forEach(target=>{

snobs.forEach(from=>{

const launch=

calcLaunch(
arrival,
from,
target,
SNOB_SPEED
);

allSnobs.push({

from,
target,

launch,

time:
launch.getTime(),

type:
"NEMES"

});

});

});

allSnobs.sort(
(a,b)=>
a.time-b.time
);

let bestSnob=null;

function searchSnob(
current,
usedSources,
targetCount,
startIndex
){

const neededAssignments =
Math.min(
snobs.length,
targets.length*snobPer
);

const valid=

current.length >=
neededAssignments;

if(valid){

const times=
current
.map(
x=>x.time
)
.sort(
(a,b)=>a-b
);

const avg =
times.reduce(
(a,b)=>a+b,
0
)/times.length;

let spread=0;

times.forEach(t=>{

spread+=Math.abs(
t-avg
);

});

if(
!bestSnob ||
spread<
bestSnob.spread
){

bestSnob={

spread,

picked:
[...current]

};

}

return;

}

for(
let i=startIndex;
i<allSnobs.length;
i++
){

const x=
allSnobs[i];

if(
usedSources.has(
x.from
)
)
continue;

if(
targetCount[
x.target
]>=snobPer
)
continue;

usedSources.add(
x.from
);

targetCount[
x.target
]++;

current.push(x);

searchSnob(

current,
usedSources,
targetCount,
i+1

);

current.pop();

usedSources.delete(
x.from
);

targetCount[
x.target
]--;

}

}

searchSnob(

[],

new Set(),

Object.fromEntries(
targets.map(
t=>[t,0]
)
),

0

);
if(bestSnob){

output.push(
...bestSnob.picked
);

}

}



output.sort(
(a,b)=>
a.time-b.time
);

const arrivalText=
$("#arrivalTime").val();

const formatted=

`[b]Csapódás:[/b] ${arrivalText}

`+

output.map(x=>{

const d=x.launch;

const pad=n=>
String(n).padStart(
2,
"0"
);

const launch=

pad(
d.getHours()
)+":"+

pad(
d.getMinutes()
)+":"+

pad(
d.getSeconds()
);

const color=

x.type==="NUKE"
? "red"
: "green";

return(

`[b]Innen:[/b] [coord]${x.from}[/coord]
[b]Ide:[/b] [coord]${x.target}[/coord]
[b]Indítás:[/b] [color=${color}]${launch}[/color]

`

);

}).join("");

$("#plannerOutput").val(
formatted
);

}); // <-- EZ ZÁRJA LE A plannerCalc clicket



