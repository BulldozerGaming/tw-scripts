function enableMassDrag(){

const hud=$("#crytekMassHud");

let dragging=false;

let ox=0;

let oy=0;

hud.on(
"mousedown",
function(e){

if(
$(e.target).closest(
"input,textarea,button,select"
).length
){
return;
}

bringHudToFront(
hud
);

e.preventDefault();

dragging=true;

ox=
e.clientX-
hud.offset().left;

oy=
e.clientY-
hud.offset().top;

});

$(document)

.on(
"mousemove.massPlanner",
function(e){

if(!dragging)
return;

hud.css({

left:
(
e.clientX-ox
)+"px",

top:
(
e.clientY-oy
)+"px"

});

})

.on(
"mouseup.massPlanner",

function(){

dragging=false;

});

