}

rows.forEach((row,index)=>{

txt+="[*]";

if(index===0){

txt+=

"[coord]"+

coord+

"[/coord]";

}

txt+=

"[|]"+

(

row.where.includes(
"fal"
)

?

"[b]Faluban[/b]"

:

"Úton"

);

let arr=

[...row.units];

const militiaIndex=

game_data.units.indexOf(
"militia"
);

if(

militiaIndex!==-1

){

arr.splice(

militiaIndex,

1

);

}

arr.forEach((v,i)=>{

const isLast=

i===arr.length-1;

if(

isLast &&

String(v)!=="0" &&

String(v)!==""

){

txt+=

"[|][color=#ff0000][b]"+

v+

"[/b][/color]";

}else{

txt+=

"[|]"+v;

}

});

txt+="\n";

});

}

txt+="[/table]";

$("#frontlineCoords")

.val(txt);

}

