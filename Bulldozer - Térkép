function updateCoordInput(){

let coords=[
...window.selectedVillages
];

const column=
$("#coordColumn")
.is(":checked");

const bb=
$("#coordBB")
.is(":checked");

const code=
$("#coordCode")
.is(":checked");

/* BB és CODE kizárják egymást */

$("#coordBB").prop(
"disabled",
code
);

$("#coordCode").prop(
"disabled",
bb
);

/* BB */

if(bb){

coords=
coords.map(

x=>
"[coord]"+x+"[/coord]"

);

}

const separator=
column
? "\n"
: " ";

let output=
coords.join(
separator
);

/* CODE */

if(code){

output=
"[code]"+
output.trim()+
"[/code]";

}

$("#coordPickerInput")
.val(output);

window.lastCoordRender=
output;

}




function drawVillageSelection(){

$(".coordVillageMark")
.remove();

window.selectedVillages.forEach(coord=>{

const parts=
coord.split("|");

const village=
TWMap.villages[
(parts[0]*1000)+
parseInt(parts[1])
];

if(
!village ||
!village.id
)return;

const el=
$("#map_village_"+village.id);

if(!el.length)
return;

const overlay = $(`

<div class="coordVillageMark"

style="

width:52px;

height:37px;

position:absolute;

left:${el.css("left")};

top:${el.css("top")};

outline:
rgba(51,255,0,.9)
solid 3px;

background:
rgba(0,255,0,.12);

pointer-events:none;

box-sizing:border-box;

z-index:60;

"

></div>

`);

overlay.appendTo(
el.parent()
);

overlay[0].markVillageCoord =
coord;

});

}

function enableCoordPicker(){


if(
!window.coordSpawnHooked
){

window.coordSpawnHooked=true;

const oldSpawn=
TWMap.mapHandler.spawnSector;

TWMap.mapHandler.spawnSector=
function(data,sector){

oldSpawn.call(
this,
data,
sector
);

setTimeout(
drawVillageSelection,
0
);

};

}

if(window.coordPickerInitialized)
return;

window.coordPickerInitialized=true;

window.coordPickerEnabled=false;

/* EREDETI MAP CLICK ELMENTÉS */

window.coordOldClick =
TWMap.mapHandler.onClick;

/* SAJÁT CLICK HANDLER */

TWMap.mapHandler.onClick=
function(x,y,event){

if(!window.coordPickerEnabled){

return window.coordOldClick
? window.coordOldClick(
x,
y,
event
)
: true;

}

const coord=
x+"|"+y;

const village=
TWMap.villages[
(x*1000)+y
];

if(!village)
return false;

const idx=
window.selectedVillages
.indexOf(coord);

if(idx>-1){

window.selectedVillages.splice(
idx,
1
);

}else{

window.selectedVillages.push(
coord
);

}

updateCoordInput();

drawVillageSelection();

/* KH popup tiltás */

return false;

};

}





