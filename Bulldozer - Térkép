/* BB OUTPUT */

const defenseMap=

window.frontlineDefenseCache||{};

const world=

location.hostname;

const units=

game_data.units.filter(

u=>u!=="militia"

);

units.push("att");

let txt=

"[table]\n"+

"[**]Falu[||]Hol?"+

units.map(u=>{

if(u==="att"){

return "[||][img]https://"+

world+

"/graphic/unit/att.webp[/img]";

}

return "[||][img]https://"+

world+

"/graphic/unit/unit_"+

u+

".webp[/img]";

}).join("")

+

"[/**]\n";

for(

const coord

of coords

){

