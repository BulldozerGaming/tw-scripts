function getForumCoords(){

const forumId=

localStorage.getItem(
"crytek_forum_id"
);

const threadId=

localStorage.getItem(
"crytek_thread_id"
);

const cacheKey=

"crytek_forum_cache_"

+

forumId

+

"_"

+

threadId;


const cacheTimeKey=

cacheKey

+

"_time";

const now=Date.now();

const cached=

localStorage.getItem(
cacheKey
);

const cacheTime=

parseInt(

localStorage.getItem(
cacheTimeKey
)

||0);


if(

cached!==null

&&

now-cacheTime<3000

){

return cached

? cached.split(" ")

: [];

}


let result=[];

$.ajax({

url:

game_data.link_base_pure+

"forum&screenmode=view_thread&"

+

"forum_id="+forumId+

"&thread_id="+threadId,

async:false,

success:function(html){

result=[

...new Set(

(

$(html)

.find(
".text,.post_text"
)

.text()

.match(
/\d{1,3}\|\d{1,3}/g
)

||

[]

)

)

];

}

});


localStorage.setItem(

cacheKey,

result.join(" ")

);

localStorage.setItem(

cacheTimeKey,

now
);

return result;

}



