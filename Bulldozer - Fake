function syncUsedWithCommands(){

const outgoings=$("#commands_outgoings");

if(!outgoings.length){

return;

}

const usedKey=
"crytek_fake_used_"+
game_data.village.id;

const oldUsed=
JSON.parse(
localStorage.getItem(usedKey)
||"[]"
);

let activeCoords=[];


outgoings
.find("tr")
.each(function(){

const txt=$(this).text();

if(

txt.includes("visszavont")

||

txt.includes("Visszavont")

){

return;

}

const match=
txt.match(/\d{1,3}\|\d{1,3}/);

if(match){

activeCoords.push(
match[0]
);

}

});


const newUsed=

oldUsed.filter(
coord=>activeCoords.includes(coord)
);


localStorage.setItem(

usedKey,

JSON.stringify(
newUsed
)

);


updateStats();


const removedSomething=

oldUsed.length>
newUsed.length;


const arrivalVisible=

$("#crytekArrival")
.is(":visible");


const arrivalText=

$("#crytekArrival")
.text()
.trim();


const allAttacked=

arrivalText.includes(
"Mindenhova"
)

||
arrivalText.includes(
"Minden éjszakaiba"
);



if(

removedSomething

&&

allAttacked

){

window.requestAnimationFrame(()=>{

$("#crytekFakeBtn")
.trigger("click");

});

}

}





