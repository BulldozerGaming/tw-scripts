"crytek_fake_mode"
)

||

"coords";


if(
sourceMode==="coords"
){

coords=

(

localStorage.getItem(
"crytek_fake_coords"
)

||

""

)

.trim();

}else{

const forumId=

localStorage.getItem(
"crytek_forum_id"
);

const threadId=

localStorage.getItem(
"crytek_thread_id"
);


if(

!forumId

||

!threadId

){

updateStatus(
"Nincs Fórum ID vagy Thread ID"
);

stopFakeLock();

return;

}


coords=

getForumCoords()

.join(" ");

}


if(!coords){

updateStatus(
"Nincs koordináta megadva"
);

stopFakeLock();

return;

}


/*

KÉSŐBB:

night start

units

slowest unit

world speed

unit speed

stb

*/





const nightStart = parseInt(

localStorage.getItem(
"crytek_fake_night"
)

|| 22

);


let slowest=

localStorage.getItem(
"crytek_fake_slowest"
)

|| "ram";

if(
!AVAILABLE_UNITS.length
){

updateStatus(
"Nincs támogatott egység"
);

stopFakeLock();

return;

}

if(
!AVAILABLE_UNITS.includes(
slowest
)
){

slowest=
AVAILABLE_UNITS[0];

}


const worldSpeed =

parseFloat(
game_data.world_speed
)

|| 1;


const unitSpeed =

parseFloat(

game_data.unit_speed

|| 1

);


if(
isNaN(
nightStart
)
){

updateStatus(
"Nincs éjszakai kezdete"
);

stopFakeLock();

return;

}








const coordList =

coords

.split(/\s+/)

.filter(Boolean);



const usedKey =

"crytek_fake_used_"

+

game_data.village.id;


let used =

JSON.parse(

localStorage.getItem(
usedKey
)

|| "[]"

);



const noRepeat=

localStorage.getItem(
"crytek_no_repeat"
)

==="1";


const previewKey=

"crytek_preview_index_"

+

game_data.village.id;


let previewIndex=

parseInt(

localStorage.getItem(
previewKey
)

|| 0

);



let available=

noRepeat

?

coordList.filter(
c=>!used.includes(c)
)

:

[...coordList];



if(
available.length===0
){

updateStatus(
"Mindenhova támadunk"
);

updateStats();

stopFakeLock();

return;

}



const previewPool=[

...available

];



if(
previewIndex>=previewPool.length
){

previewIndex=0;

}



const mode=

localStorage.getItem(
"crytek_coord_mode"
)

|| "linear";


let firstCoord=null;

let tested=0;

const pool=[...previewPool];


while(

tested < previewPool.length

&&

pool.length>0

){

let candidate;


if(
mode==="random"
){

const randIndex=

Math.floor(
Math.random()
*
pool.length
);

candidate=

pool[
randIndex
];

pool.splice(
randIndex,
1
);

}else{

candidate=

pool[
previewIndex
%

pool.length
];


previewIndex++;

if(
previewIndex>=pool.length
){

previewIndex=0;

}

}


const parts=
candidate.split("|");


const currentX=
parseInt(
game_data.village.coord.split("|")[0]
);

const currentY=
parseInt(
game_data.village.coord.split("|")[1]
);


const targetX=
parseInt(parts[0]);

const targetY=
parseInt(parts[1]);


const distance=
Math.sqrt(

Math.pow(
targetX-currentX,
2
)

+

Math.pow(
targetY-currentY,
2
)

);


const minutes=

distance

*

(

UNIT_SPEEDS[slowest]

/

worldSpeed

/

unitSpeed

);


const arrivalTmp=

new Date(

Date.now()

+

minutes

*

60000

);


const h=
arrivalTmp.getHours();


if(

h < 7

||

h >= nightStart

){

tested++;

continue;

}


firstCoord=
candidate;

break;

}


if(
!firstCoord
){

updateStatus(
"Minden éjszakaiba érkezne"
);

updateStats();

stopFakeLock();

return;

}










if(
!/^\d+\|\d+$/
.test(firstCoord)
){

updateStatus(
"Hibás koordináta"
);

stopFakeLock();

return;

}

const parts =
firstCoord.split("|");



const currentX=

parseInt(
game_data.village.coord.split("|")[0]
);

const currentY=

parseInt(
game_data.village.coord.split("|")[1]
);

const targetX=
parseInt(parts[0]);

const targetY=
parseInt(parts[1]);

const distance = Math.sqrt(

Math.pow(
targetX-currentX,
2
)

+

Math.pow(
targetY-currentY,
2
)

);


const minutes =

distance

*

(

UNIT_SPEEDS[slowest]

/

worldSpeed

/

unitSpeed

);


const arrival =

new Date(

Date.now()

+

minutes

*

60000

);




$("input[name='x']")
.val(
parts[0]
);

$("input[name='y']")
.val(
parts[1]
);

$("input[name='attack']")
.prop(
"checked",
true
)
.trigger("change");

AVAILABLE_UNITS.forEach(unit=>{

$(`input[name='${unit}']`)

.val(

localStorage.getItem(
"fake_"+unit
)

|| 0

);

});



updateStatus("");

$("#crytekArrival")

.hide()

.empty();


setArrivalTime(
arrival
);

updateStats();

window.crytekCurrentCoord =
firstCoord;

localStorage.setItem(

"crytek_current_coord_"+game_data.village.id,

firstCoord

);


localStorage.setItem(
previewKey,
previewIndex
);


UI.SuccessMessage(
"Koordináta betöltve"
);

setTimeout(
stopFakeLock,
300
);

return false;

}
);



$(document).on(
"submit",
"#command-data-form",
function(){

if(
!location.href.includes(
"try=confirm"
)
){
return;
}

const currentCoord=

window.crytekCurrentCoord

||

localStorage.getItem(

"crytek_current_coord_"

+

game_data.village.id

);


if(
!currentCoord
)
return;


const usedKey=

"crytek_fake_used_"

+

game_data.village.id;


let used=

JSON.parse(

localStorage.getItem(
usedKey
)

|| "[]"

);


if(

!used.includes(
currentCoord
)

){

used.push(
currentCoord
);

localStorage.setItem(

usedKey,

JSON.stringify(
used
)

);

}



localStorage.setItem(

"crytek_auto_next_"+game_data.village.id,

"1"

);


window.crytekCurrentCoord=null;

localStorage.removeItem(

"crytek_current_coord_"

+

game_data.village.id

);

syncUsedWithCommands();

});



$(document).on(
"click",
".closeHud",
function(){

$(
$(this)
.data(
"target"
)

)

.hide();

});



$(document)

.on(
"mousedown",
".crytekHudHeader",
function(e){

if(

$(e.target)

.is(

"textarea,input,select"

)

)

return;



const hud=

$(this)

.parent();


const ox=

e.pageX

-

hud.offset().left;


const oy=

e.pageY

-

hud.offset().top;



$(document)

.on(
"mousemove.crytekDrag",
function(ev){

hud.css({

left:

ev.pageX-ox,

top:

ev.pageY-oy

});

});



$(document)

.one(
"mouseup",
function(){

$(document)

.off(
".crytekDrag"
);

});

});





$(document).ready(function(){

createUI();

updateStats();



function watchOutgoingChanges(){

const outgoings=

document.getElementById(
"commands_outgoings"
);

if(
!outgoings
)
return;


const observer=

new MutationObserver(()=>{

syncUsedWithCommands();

});


observer.observe(

outgoings,

{

childList:true,

subtree:true

}

);

}



watchOutgoingChanges();


const autoKey=

"crytek_auto_next_"

+

game_data.village.id;


if(

localStorage.getItem(
autoKey
)

==="1"

){

localStorage.removeItem(
autoKey
);


requestAnimationFrame(()=>{

updateStats();

$("#crytekFakeBtn")
.click();

});

}

}
);



















})();
