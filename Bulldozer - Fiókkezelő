function formatDuration(sec){

const h=Math.floor(sec/3600);
const m=Math.floor((sec%3600)/60);
const s=Math.floor(sec%60);

return `${h} óra ${m} perc ${s} mp`;

}

function calculateTemplateInfo(data){

const speed =
parseFloat(
localStorage.getItem(
"crytek_fiokkezelo_world_speed"
)
) || 1;

let barracks=0;
let stable=0;
let workshop=0;

let popBarracks=0;
let popStable=0;
let popWorkshop=0;

Object.entries(data).forEach(([unit,count])=>{

if(!BASE_TIMES[unit]) return;

const time=
(BASE_TIMES[unit]*count)/speed;

switch(unit){

case "spear":
case "sword":
case "axe":
case "archer":

barracks+=time;
popBarracks+=count*POPULATION[unit];
break;

case "spy":
case "light":
case "heavy":

stable+=time;
popStable+=count*POPULATION[unit];
break;

case "ram":
case "catapult":

workshop+=time;
popWorkshop+=count*POPULATION[unit];
break;

}

});

return{

population:
popBarracks+
popStable+
popWorkshop,

barracks:
formatDuration(barracks),

stable:
formatDuration(stable),

workshop:
formatDuration(workshop),

popBarracks,
popStable,
popWorkshop

};

}



