$(function () {

    const screen =
        getUrlParameter('screen');

    if (
        screen !== 'info_player' &&
        screen !== 'info_ally'
    ) {
        return;
    }

    const statTitle =
        $('.DSULT-toggle-stats').first();

    if (!statTitle.length) {
        return;
    }

    // csak 1 nyíl
    $('#DSULT_toggle_icon').remove();

    statTitle.find('td').append(`

        <span id="DSULT_toggle_icon"
              style="
                float:right;
                font-size:16px;
              ">
            ▼
        </span>

    `);

    // PLAYER BLOKKOK
    if (screen === 'info_player') {

        const lastGraph =
            $('tr[id^="DSULT_opt_"]:last');

        $('#DSULT_KILL_BOX')
            .closest('tr')
            .prev()
            .addBack()
            .insertAfter(lastGraph);

        $('#DSULT_DAILY_BOX')
            .closest('tr')
            .prev()
            .addBack()
            .insertAfter(
                $('#DSULT_KILL_BOX')
                    .closest('tr')
            );
    }

    // KLÁN BLOKKOK
    if (screen === 'info_ally') {

        const lastGraph =
            $('tr[id^="DSULT_opt_"]:last');

        $('#DSULT_ALLY_KILL_BOX')
            .closest('tr')
            .prev()
            .addBack()
            .insertAfter(lastGraph);

        $('#DSULT_CONT_BOX')
            .closest('tr')
            .prev()
            .addBack()
            .insertAfter(
                $('#DSULT_ALLY_KILL_BOX')
                    .closest('tr')
            );
    }

    // minden rejtett stat
const rows =
        $('.DSULT-hidden-stat');

rows.hide();

    // katt
    statTitle.on('click', function () {

        const visible =
            rows.first().is(':visible');

        if (visible) {

            rows.hide();

            $('#DSULT_toggle_icon')
                .text('▼');

        } else {

            rows.show();

            // csak aktív grafikon
            $('.DSULT-select')
                .trigger('change');

            $('#DSULT_toggle_icon')
                .text('▲');
        }
    });
});

