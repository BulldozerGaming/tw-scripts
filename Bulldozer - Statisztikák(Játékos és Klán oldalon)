async function loadDominanceStat() {

    if (getUrlParameter('screen') !== 'info_ally') {
        return;
    }

    let allyId = getUrlParameter('id');

    $('.vis').first().find('tbody').prepend(`


        <tr>
            <td colspan="2">

                <div class="DSULT-daily-box" id="DSULT_DOM_BOX">
                    <div class="DSULT-daily-row">
                        Betöltés...
                    </div>
                </div>

            </td>
        </tr>

    `);

    try {

        let response = await $.get(

            `/game.php?village=${game_data.village.id}` +
            `&screen=ranking` +
            `&mode=dominance`
        );

        let doc = $('<div>').html(response);

        let found = false;

        doc.find('.vis tr').each(function () {

            let cols = $(this).find('td');

            if (cols.length < 2) {
                return;
            }

            let href =
                cols.eq(0)
                    .find('a')
                    .attr('href') || '';

            if (
                !href.includes('screen=info_ally') ||
                !href.includes('id=' + allyId)
            ) {
                return;
            }

            let percent =
                cols.eq(1)
                    .text()
                    .trim();

            $('#DSULT_DOM_BOX').html(`

                <div class="DSULT-daily-row">

                    <div class="DSULT-daily-left">
                        👑 Világ dominancia
                    </div>

                    <div class="DSULT-daily-right">
                        <strong>${percent}</strong>
                    </div>

                </div>

            `);

            found = true;

            return false;
        });

        if (!found) {

            $('#DSULT_DOM_BOX').html(`

                <div class="DSULT-daily-row">

                    <div class="DSULT-daily-left">
                        👑 Világ dominancia
                    </div>

                    <div class="DSULT-daily-right">
                        Nincs adat
                    </div>

                </div>

            `);
        }

    } catch (e) {

        console.log(e);

        $('#DSULT_DOM_BOX').html(`

            <div class="DSULT-daily-row">

                <div class="DSULT-daily-left">
                    👑 Világ dominancia
                </div>

                <div class="DSULT-daily-right">
                    Nincs adat
                </div>

            </div>

        `);
    }
}

