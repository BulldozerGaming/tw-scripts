/* ===========================
   START GET URL PARAMETER FUNCTION
=========================== */

    function getUrlParameter(sParam) {

        let sPageURL = win.location.search.substring(1);

        let sURLVariables = sPageURL.split('&');

        let sParameterName;

        for (let i = 0; i < sURLVariables.length; i++) {

            sParameterName = sURLVariables[i].split('=');

            if (sParameterName[0] === sParam) {

                return sParameterName[1] === undefined
                    ? true
                    : decodeURIComponent(sParameterName[1]);
            }
        }
    }

/* ===========================
   END GET URL PARAMETER FUNCTION
=========================== */





/* ===========================
   START GENERATE DSULT IMAGE FUNCTION
=========================== */

    function generateDSUltimateImage(
        s,
        w,
        t,
        id,
        diagramType,
        width
    ) {

        let data = '';

        data += '<a href="https://ds-ultimate.de/in/';
        data += s + w + '/';
        data += t + '/';
        data += id;
        data += '" target="_blank">';

        data += '<img src="https://ds-ultimate.de/api/picture/';
        data += s + '-';
        data += w + '-';
        data += t + '-';
        data += id + '-';
        data += diagramType + '-';
        data += width + '-';
        data += Math.round(width / 3);
       data += '.png" style="max-width:100%;height:auto;display:block;">';

        data += '</a>';

        return data;
    }

/* ===========================
   END GENERATE DSULT IMAGE FUNCTION
=========================== */





