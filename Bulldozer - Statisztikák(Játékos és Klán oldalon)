    let continents = [44, 45, 54, 55];

    $('.vis').first().find('tbody').append(`

        <tr class="DSULT-title-row DSULT-hidden-stat">
            <td colspan="2"
                style="
                    padding:18px 14px 12px 14px;
                    font-size:18px;
                    font-weight:700;
                    color:#5a3515;
                    border-top:1px solid #d8c39c;
                ">
                🌍 Kontinens helyezések
            </td>
        </tr>

        <tr class="DSULT-hidden-stat">
            <td colspan="2">

                <div class="DSULT-daily-box" id="DSULT_CONT_BOX">
                    <div class="DSULT-daily-row">Betöltés...</div>
                </div>

            </td>
        </tr>

    `);

    let rows = '';

    for (let k of continents) {

        let found = false;

        try {

            let response = await $.get(

                `/game.php?village=${game_data.village.id}` +
                `&screen=ranking` +
                `&mode=con_ally` +
                `&con=${k}`
            );

            let doc = $('<div>').html(response);

            doc.find('.vis tr').each(function () {

                let cols = $(this).find('td');

                if (cols.length < 3) {
                    return;
                }

                let href =
                    cols.eq(1)
                        .find('a')
                        .first()
                        .attr('href') || '';

                if (
                    !href.includes('screen=info_ally') ||
                    !href.includes('id=' + allyId)
                ) {
                    return;
                }

                let rank =
                    cols.eq(0).text().trim();

                let points =
                    cols.eq(2).text().trim();

                rows += `

                    <div class="DSULT-daily-row">

                        <div class="DSULT-daily-left">
                            🌍 K${k}
                        </div>

                        <div class="DSULT-daily-right">
                            #${rank}
                            •
                            ${points} pont
                        </div>

                    </div>

                `;

                found = true;

                return false;
            });

        } catch (e) {

            console.log(e);
        }

        if (!found) {

            rows += `

                <div class="DSULT-daily-row">

                    <div class="DSULT-daily-left">
                        🌍 K${k}
                    </div>

                    <div class="DSULT-daily-right">
                        Nincs adat
                    </div>

                </div>

            `;
        }
    }

    $('#DSULT_CONT_BOX').html(rows);
}

