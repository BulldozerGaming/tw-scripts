async function loadSpeeds(){

let worldSpeed=
parseFloat(
localStorage.getItem(
"crytek_world_speed"
)
);

let unitSpeed=
parseFloat(
localStorage.getItem(
"crytek_unit_speed"
)
);

if(
!isNaN(worldSpeed)
&&
!isNaN(unitSpeed)
){

return{

worldSpeed,
unitSpeed

};

}

return new Promise(
resolve=>{

$.get(

"/interface.php?func=get_config",

xml=>{

worldSpeed=
parseFloat(
$(xml)
.find("speed")
.text()
);

unitSpeed=
parseFloat(
$(xml)
.find("unit_speed")
.text()
);

localStorage.setItem(
"crytek_world_speed",
worldSpeed
);

localStorage.setItem(
"crytek_unit_speed",
unitSpeed
);

resolve({

worldSpeed,
unitSpeed

});

}

);

}

);

}

