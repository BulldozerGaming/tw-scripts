function findPossibleTrains(){

const rows=
getRows();

const grouped={};

rows.forEach(
row=>{

const target=
row.cells[1]
.innerText
.trim();

const timeText=
row.cells[5]
.innerText;

const match=
timeText.match(
/(\d+):(\d+):(\d+):(\d+)/
);

if(!match)return;

const ms=

parseInt(match[1])*3600000+

parseInt(match[2])*60000+

parseInt(match[3])*1000+

parseInt(match[4]);

if(
!grouped[target]
){

grouped[target]=[];

}

grouped[target].push({

row,
ms

});

});

const results=
new Set();

Object.values(
grouped
).forEach(
attacks=>{

attacks.sort(
(a,b)=>
a.ms-b.ms
);

for(
let i=0;
i<attacks.length;
i++
){

const cluster=
attacks.filter(
x=>

Math.abs(
x.ms-
attacks[i].ms
)

<=1000

);

if(
cluster.length>=4
){

cluster.forEach(
c=>
results.add(
c.row
)
);

}

}

});

rows.forEach(
r=>
r.style.display='none'
);

[...results].forEach(
r=>
r.style.display=''
);

const visible=

getRows().filter(
r=>

r.style.display!=="none"

).length;

const header=

document.querySelector(
'#incomings_table th'
);

if(
header
){

header.textContent=

`Parancs (${visible})`;

}

if(
results.size===0
){

UI.InfoMessage(

'Nincs a Rendezés / Szűrésnek megfelelő találat.',

5000

);

}else{

UI.SuccessMessage(

'Vonatok találva: '+

results.size,

5000

);

}

}









function findSameSource(){

const rows=
getRows();

const grouped={};

rows.forEach(
row=>{

const sourceText=

row.cells[2]
.textContent;

const coord=

sourceText.match(
/\d+\|\d+/
);

if(
!coord
){
return;
}

const key=
coord[0];

if(
!grouped[key]
){

grouped[key]=[];

}

grouped[key].push(
row
);

}
);

const results=
new Set();

Object.values(
grouped
).forEach(
group=>{

if(
group.length>=2
){

group.forEach(
row=>
results.add(
row
)
);

}

}
);

rows.forEach(
row=>{

row.style.display=

results.has(
row
)

?

''

:

'none';

}
);

const visible=

getRows().filter(
r=>

r.style.display!=="none"

).length;

const header=

document.querySelector(
'#incomings_table th'
);

if(
header
){

header.textContent=

`Parancs (${visible})`;

}

if(
results.size===0
){

UI.InfoMessage(

'Nincs a Rendezés / Szűrésnek megfelelő találat.',

5000

);

}else{

UI.SuccessMessage(

'Azonos forrású támadások: '+

results.size,

5000

);

}

}










function sortRowsByColumn(
column
){

if(
column==="default"
){
return;
}

const table=
document.querySelector(
'#incomings_table tbody'
);

const incomingTable=
document.querySelector(
'#incomings_table'
);

incomingTable.style.width='100%';
incomingTable.style.tableLayout='fixed';

const rows=

getRows().filter(
row=>

row.style.display!=="none"

);

rows.sort(
(a,b)=>{

const av=
a.cells[
column
]
.textContent
.trim();

const bv=
b.cells[
column
]
.textContent
.trim();

const na=
parseFloat(
av.replace(
',',
'.'
)
);

const nb=
parseFloat(
bv.replace(
',',
'.'
)
);

if(
!isNaN(na)
&&
!isNaN(nb)
){

return na-nb;

}

return av.localeCompare(
bv,
'hu'
);

}

);

const selectAllRow=

[...table.querySelectorAll(
'tr'
)]

.find(
tr=>

tr.innerText.includes(
'összes kiválasztása'
)

);

rows.forEach(
row=>{

if(
selectAllRow
){

table.insertBefore(
row,
selectAllRow
);

}else{

table.appendChild(
row
);

}

}
);

incomingTable.style.tableLayout='';

}













