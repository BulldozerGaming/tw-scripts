function getUnitLabel(
distance,
arrival,
speeds
){

const now=
Date.now();

const diffMin=
(
arrival-now
)
/60000;

let best=
"";

for(
const[
unit,
speed
]

of Object.entries(
UNIT_SPEED
)
){

const needed=

distance*
speed/
(
speeds.worldSpeed*
speeds.unitSpeed
);

if(
needed<=diffMin
){

best=
unit;

}

}

const labels={

spear:"Lándzsa",
sword:"Kard",
axe:"Bárd",
spy:"Kém",
light:"KL",
heavy:"NL",
ram:"Kos",
catapult:"Katapult",
snob:"FN"

};

return labels[
best
]||"?"

}

